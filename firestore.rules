rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    function userDoc(userId) {
      return get(/databases/$(database)/documents/users/$(userId));
    }

    function myUser() {
      return userDoc(uid());
    }

    function myRole() {
      return myUser().data.role;
    }

    function isCoach() {
      return signedIn() && myRole() == 'coach';
    }

    function isLearner() {
      return signedIn() && myRole() == 'learner';
    }

    function isObserver() {
      return signedIn() && myRole() == 'observer';
    }

    // Ops-only accounts use role == 'admin'; coach/learner/observer may also set isAdmin.
    function isAdmin() {
      return signedIn() && (
        myRole() == 'admin'
        || myUser().data.isAdmin == true
      );
    }

    function relationId(a, b) {
      return a + '_' + b;
    }

    function hasCoachLearnerLink(coachId, learnerId) {
      return exists(
        /databases/$(database)/documents/coachLearnerRelations/$(relationId(coachId, learnerId))
      );
    }

    function hasObserverLearnerLink(observerId, learnerId) {
      return exists(
        /databases/$(database)/documents/observerLearnerRelations/$(relationId(observerId, learnerId))
      );
    }

    function isAssignedCoach(learnerId) {
      return isCoach() && hasCoachLearnerLink(uid(), learnerId);
    }

    function isAssignedObserver(learnerId) {
      return isObserver() && hasObserverLearnerLink(uid(), learnerId);
    }

    // Learner owner, assigned coach, or assigned observer (read-only on writes elsewhere)
    function canAccessLearner(learnerId) {
      return (isLearner() && uid() == learnerId)
        || isAssignedCoach(learnerId)
        || isAssignedObserver(learnerId);
    }

    function unchangedKeys(keys) {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(keys);
    }

    function stringLen(field, min, max) {
      return request.resource.data[field] is string
        && request.resource.data[field].size() >= min
        && request.resource.data[field].size() <= max;
    }

    function inviteDoc() {
      return get(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode));
    }

    function validCommentCreate(learnerId, targetKind, targetId) {
      return canAccessLearner(learnerId)
        && request.resource.data.id is string
        && request.resource.data.learnerId == learnerId
        && request.resource.data.targetKind == targetKind
        && request.resource.data.targetId == targetId
        && request.resource.data.authorId == uid()
        && request.resource.data.authorRole == myRole()
        && request.resource.data.authorDisplayName is string
        && request.resource.data.authorDisplayName.size() > 0
        && request.resource.data.authorDisplayName.size() <= 120
        && stringLen('body', 1, 4000)
        && request.resource.data.createdAt is string
        && request.resource.data.updatedAt is string;
    }

    function validCommentUpdate() {
      return resource.data.authorId == uid()
        && request.resource.data.authorId == resource.data.authorId
        && unchangedKeys([
          'id', 'learnerId', 'targetKind', 'targetId',
          'authorId', 'authorRole', 'authorDisplayName', 'createdAt'
        ])
        && stringLen('body', 1, 4000)
        && request.resource.data.updatedAt is string;
    }

    // —— Invites (code is secret; admin console or Admin SDK / CLI creates them) ——
    match /invites/{code} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isAdmin()
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.role in ['admin', 'coach', 'learner', 'observer']
        && request.resource.data.used == false
        && request.resource.data.createdAt is string
        && (
          request.resource.data.role != 'learner'
          || (
            request.resource.data.coachId is string
            && request.resource.data.coachId.size() > 0
          )
        )
        && (
          request.resource.data.role != 'observer'
          || (
            request.resource.data.learnerIds is list
            && request.resource.data.learnerIds.size() > 0
          )
        );
      allow delete: if isAdmin();
      allow update: if signedIn()
        && resource.data.used == false
        && request.resource.data.used == true
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['used'])
        && request.auth.token.email.lower() == resource.data.email.lower();

      // Admin / Ops API may stamp invite email delivery metadata.
      allow update: if isAdmin()
        && unchangedKeys([
          'email', 'role', 'coachId', 'learnerIds', 'displayName', 'used', 'createdAt'
        ])
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['emailSentAt', 'emailStatus', 'emailError', 'emailSendCount'])
        && (
          !('emailStatus' in request.resource.data)
          || request.resource.data.emailStatus in ['pending', 'sent', 'failed']
        )
        && (
          !('emailSendCount' in request.resource.data)
          || request.resource.data.emailSendCount is int
          || request.resource.data.emailSendCount is float
        );
    }

    // —— Users ——
    match /users/{userId} {
      allow get: if signedIn() && (
        isAdmin()
        || uid() == userId
        || isAssignedCoach(userId)
        || isAssignedObserver(userId)
        || (isLearner() && resource.data.role == 'coach' && hasCoachLearnerLink(userId, uid()))
        || (isLearner() && resource.data.role == 'observer' && hasObserverLearnerLink(userId, uid()))
      );
      allow list: if isAdmin();

      allow create: if signedIn()
        && uid() == userId
        && request.resource.data.id == userId
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 120
        && request.resource.data.role in ['admin', 'coach', 'learner', 'observer']
        && request.resource.data.inviteCode is string
        && exists(/databases/$(database)/documents/invites/$(request.resource.data.inviteCode))
        && inviteDoc().data.used == false
        && inviteDoc().data.email.lower() == request.resource.data.email.lower()
        && inviteDoc().data.role == request.resource.data.role
        && (
          request.resource.data.role != 'learner'
          || request.resource.data.coachId == inviteDoc().data.coachId
        );

      allow update: if signedIn()
        && uid() == userId
        && unchangedKeys([
          'id', 'role', 'isAdmin', 'email', 'coachId', 'inviteCode', 'createdAt', 'lehrbeginnYear'
        ]);

      // Assigned coach may set Lehrbeginn year on a learner profile.
      // Client SDK stores numbers as float — accept int or float.
      allow update: if isAssignedCoach(userId)
        && resource.data.role == 'learner'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['lehrbeginnYear', 'updatedAt'])
        && request.resource.data.updatedAt is string
        && (
          request.resource.data.lehrbeginnYear == null
          || (
            (request.resource.data.lehrbeginnYear is int
              || request.resource.data.lehrbeginnYear is float)
            && request.resource.data.lehrbeginnYear >= 2000
            && request.resource.data.lehrbeginnYear <= 2100
          )
        );

      // Admin may change operational role and/or isAdmin capability.
      allow update: if isAdmin()
        && unchangedKeys(['id', 'email', 'inviteCode', 'createdAt'])
        && request.resource.data.role in ['admin', 'coach', 'learner', 'observer']
        && request.resource.data.updatedAt is string
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['role', 'isAdmin', 'updatedAt'])
        && (
          !('isAdmin' in request.resource.data)
          || request.resource.data.isAdmin is bool
        );

      allow delete: if false;

      match /contentViews/{viewId} {
        allow read: if signedIn() && uid() == userId;
        allow create, update: if signedIn()
          && uid() == userId
          && request.resource.data.id == viewId
          && request.resource.data.viewerId == userId
          && request.resource.data.learnerId is string
          && request.resource.data.targetKind in ['journal', 'report']
          && request.resource.data.targetId is string
          && request.resource.data.viewedAt is string
          && viewId == request.resource.data.learnerId + '_'
            + request.resource.data.targetKind + '_'
            + request.resource.data.targetId;
        allow delete: if signedIn() && uid() == userId;
      }
    }

    // —— Coach ↔ Lernender links ——
    match /coachLearnerRelations/{relationDocId} {
      allow read: if isAdmin() || (signedIn() && (
        resource.data.coachId == uid() || resource.data.learnerId == uid()
      ));

      allow create: if (
        signedIn()
        && request.resource.data.learnerId == uid()
        && request.resource.data.coachId is string
        && request.resource.data.id == relationDocId
        && relationDocId == relationId(request.resource.data.coachId, request.resource.data.learnerId)
        && myUser().data.role == 'learner'
        && myUser().data.coachId == request.resource.data.coachId
      ) || (
        isAdmin()
        && request.resource.data.coachId is string
        && request.resource.data.learnerId is string
        && request.resource.data.id == relationDocId
        && relationDocId == relationId(request.resource.data.coachId, request.resource.data.learnerId)
        && request.resource.data.createdAt is string
      );

      allow update: if false;
      allow delete: if isAdmin();
    }

    // —— Beobachter ↔ Lernender links (read-only viewers) ——
    match /observerLearnerRelations/{relationDocId} {
      allow read: if isAdmin() || (signedIn() && (
        resource.data.observerId == uid() || resource.data.learnerId == uid()
      ));

      allow create: if (
        signedIn()
        && request.resource.data.observerId == uid()
        && request.resource.data.learnerId is string
        && request.resource.data.id == relationDocId
        && relationDocId == relationId(request.resource.data.observerId, request.resource.data.learnerId)
        && myUser().data.role == 'observer'
        && myUser().data.inviteCode is string
        && exists(/databases/$(database)/documents/invites/$(myUser().data.inviteCode))
        && get(/databases/$(database)/documents/invites/$(myUser().data.inviteCode)).data.used == false
        && get(/databases/$(database)/documents/invites/$(myUser().data.inviteCode)).data.role == 'observer'
        && request.resource.data.learnerId
          in get(/databases/$(database)/documents/invites/$(myUser().data.inviteCode)).data.learnerIds
      ) || (
        isAdmin()
        && request.resource.data.observerId is string
        && request.resource.data.learnerId is string
        && request.resource.data.id == relationDocId
        && relationDocId == relationId(request.resource.data.observerId, request.resource.data.learnerId)
        && request.resource.data.createdAt is string
      );

      allow update: if false;
      allow delete: if isAdmin();
    }

    // —— Fixed school roadmap (read-only for clients) ——
    match /schoolRoadmapItems/{itemId} {
      allow read: if signedIn();
      allow write: if false;
    }

    // —— Per-learner data ——
    match /learners/{learnerId} {
      allow read, write: if false;

      match /semesters/{semesterId} {
        allow read: if canAccessLearner(learnerId);
        allow create, update: if isAssignedCoach(learnerId)
          && stringLen('label', 1, 120)
          && request.resource.data.status in ['planned', 'active', 'completed'];
        allow delete: if false;
      }

      match /semesterGoals/{goalId} {
        allow read: if canAccessLearner(learnerId);
        allow create, update: if isAssignedCoach(learnerId)
          && stringLen('title', 1, 200)
          && (
            !('assessmentGrade' in request.resource.data)
            || request.resource.data.assessmentGrade == null
            || request.resource.data.assessmentGrade in ['A', 'B', 'C', 'D', 'E']
          );
        allow delete: if false;
      }

      match /journalEntries/{entryId} {
        // Drafts: learner only. Submitted: learner + assigned coach/observer.
        allow read: if (isLearner() && uid() == learnerId)
          || (
            (isAssignedCoach(learnerId) || isAssignedObserver(learnerId))
            && resource.data.status == 'submitted'
          );

        allow create: if isLearner()
          && uid() == learnerId
          && request.resource.data.learnerId == learnerId
          && request.resource.data.status == 'draft'
          && request.resource.data.answers.workedOn is string
          && request.resource.data.answers.learned is string;

        allow update: if isLearner()
          && uid() == learnerId
          && request.resource.data.learnerId == learnerId
          && unchangedKeys(['learnerId', 'createdAt'])
          && request.resource.data.status in ['draft', 'submitted']
          // Once submitted, stay submitted (no revert to draft).
          && (resource.data.status != 'submitted' || request.resource.data.status == 'submitted')
          && request.resource.data.answers.workedOn is string
          && request.resource.data.answers.learned is string
          && (
            resource.data.status == 'submitted'
              ? unchangedKeys(['submittedAt'])
              : (
                request.resource.data.status == 'draft'
                  || request.resource.data.submittedAt is string
              )
          );

        // Anyone with learner access may stamp last-comment metadata after commenting.
        allow update: if canAccessLearner(learnerId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastCommentAt', 'lastCommentAuthorId', 'lastCommentAuthorName'])
          && request.resource.data.lastCommentAt is string
          && request.resource.data.lastCommentAuthorId == uid()
          && request.resource.data.lastCommentAuthorName is string
          && request.resource.data.lastCommentAuthorName.size() > 0
          && request.resource.data.lastCommentAuthorName.size() <= 120;

        allow delete: if isLearner()
          && uid() == learnerId
          && resource.data.status == 'draft';

        match /comments/{commentId} {
          allow read: if (isLearner() && uid() == learnerId)
            || (
              (isAssignedCoach(learnerId) || isAssignedObserver(learnerId))
              && get(/databases/$(database)/documents/learners/$(learnerId)/journalEntries/$(entryId)).data.status == 'submitted'
            );
          allow create: if get(/databases/$(database)/documents/learners/$(learnerId)/journalEntries/$(entryId)).data.status == 'submitted'
            && validCommentCreate(learnerId, 'journal', entryId)
            && request.resource.data.id == commentId;
          allow update: if canAccessLearner(learnerId) && validCommentUpdate();
          allow delete: if canAccessLearner(learnerId) && resource.data.authorId == uid();
        }
      }

      match /learningReports/{reportId} {
        // Drafts: learner only. Submitted: learner + assigned coach/observer.
        allow read: if (isLearner() && uid() == learnerId)
          || (
            (isAssignedCoach(learnerId) || isAssignedObserver(learnerId))
            && resource.data.status == 'submitted'
          );

        allow create: if isLearner()
          && uid() == learnerId
          && request.resource.data.learnerId == learnerId
          && request.resource.data.status == 'draft'
          && stringLen('title', 1, 200)
          && request.resource.data.bodyMarkdown is string
          && request.resource.data.bodyMarkdown.size() <= 500000;

        allow update: if isLearner()
          && uid() == learnerId
          && request.resource.data.learnerId == learnerId
          && unchangedKeys(['learnerId', 'createdAt'])
          && request.resource.data.status in ['draft', 'submitted']
          && (resource.data.status != 'submitted' || request.resource.data.status == 'submitted')
          && stringLen('title', 1, 200)
          && request.resource.data.bodyMarkdown is string
          && request.resource.data.bodyMarkdown.size() <= 500000
          && (
            resource.data.status == 'submitted'
              ? unchangedKeys(['submittedAt'])
              : (
                request.resource.data.status == 'draft'
                  || request.resource.data.submittedAt is string
              )
          );

        allow update: if canAccessLearner(learnerId)
          && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['lastCommentAt', 'lastCommentAuthorId', 'lastCommentAuthorName'])
          && request.resource.data.lastCommentAt is string
          && request.resource.data.lastCommentAuthorId == uid()
          && request.resource.data.lastCommentAuthorName is string
          && request.resource.data.lastCommentAuthorName.size() > 0
          && request.resource.data.lastCommentAuthorName.size() <= 120;

        allow delete: if isLearner()
          && uid() == learnerId
          && resource.data.status == 'draft';

        match /comments/{commentId} {
          allow read: if (isLearner() && uid() == learnerId)
            || (
              (isAssignedCoach(learnerId) || isAssignedObserver(learnerId))
              && get(/databases/$(database)/documents/learners/$(learnerId)/learningReports/$(reportId)).data.status == 'submitted'
            );
          allow create: if get(/databases/$(database)/documents/learners/$(learnerId)/learningReports/$(reportId)).data.status == 'submitted'
            && validCommentCreate(learnerId, 'report', reportId)
            && request.resource.data.id == commentId;
          allow update: if canAccessLearner(learnerId) && validCommentUpdate();
          allow delete: if canAccessLearner(learnerId) && resource.data.authorId == uid();
        }
      }

      match /companyRoadmapItems/{itemId} {
        allow read: if canAccessLearner(learnerId);
        allow create, update: if isAssignedCoach(learnerId)
          && stringLen('title', 1, 200)
          && request.resource.data.status in ['active', 'archived'];
        allow delete: if false;
      }

      match /roadmapProgress/{progressId} {
        allow read: if canAccessLearner(learnerId);

        // Learner or assigned coach may set treated; observers read-only.
        allow create, update: if (
          (
            (isLearner() && uid() == learnerId)
            || isAssignedCoach(learnerId)
          )
          && request.resource.data.learnerId == learnerId
          && request.resource.data.itemId is string
          && request.resource.data.itemType in ['school', 'company']
          && request.resource.data.treated is bool
        );

        allow delete: if false;
      }
    }
  }
}
